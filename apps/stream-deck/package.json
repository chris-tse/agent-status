{
  "name": "@status-dashboard/stream-deck",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "dev": "rollup -c -w --watch.onEnd=\"bunx @elgato/cli restart com.status-dashboard.stream-deck\"",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "bun run build && bunx @elgato/cli validate com.status-dashboard.stream-deck.sdPlugin",
    "link": "bunx @elgato/cli link com.status-dashboard.stream-deck.sdPlugin",
    "unlink": "bunx @elgato/cli unlink com.status-dashboard.stream-deck",
    "restart": "bunx @elgato/cli restart com.status-dashboard.stream-deck",
    "pack": "bun run build && bunx @elgato/cli pack com.status-dashboard.stream-deck.sdPlugin"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0",
    "@status-dashboard/model": "workspace:*",
    "ws": "latest"
  },
  "devDependencies": {
    "@elgato/cli": "latest",
    "@rollup/plugin-commonjs": "latest",
    "@rollup/plugin-node-resolve": "latest",
    "@rollup/plugin-terser": "latest",
    "@rollup/plugin-typescript": "latest",
    "@types/node": "^24.0.0",
    "@types/ws": "latest",
    "rollup": "latest",
    "tslib": "latest",
    "typescript": "5.9.3",
    "vitest": "latest"
  },
  "engines": {
    "bun": "1.3.14",
    "node": ">=24"
  },
  "packageManager": "bun@1.3.14"
}
