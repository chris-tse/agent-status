{
  "name": "status-dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:service": "bun run --filter '@status-dashboard/service' dev",
    "dev:dashboard": "bun run --filter '@status-dashboard/dashboard' dev",
    "preview:dashboard": "bun run --filter '@status-dashboard/dashboard' preview",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck && bun run typecheck:scripts",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json",
    "stream-deck:validate": "bun run --filter '@status-dashboard/stream-deck' validate",
    "stream-deck:link": "bun run --filter '@status-dashboard/stream-deck' link",
    "stream-deck:restart": "bun run --filter '@status-dashboard/stream-deck' restart"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5.9.3",
    "vitest": "latest"
  }
}
